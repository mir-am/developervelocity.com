---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>🧑‍💻 Hello, Developer!</h1>
			<p>
				Welcome to the Developer Velocity blog. We help you keep up with the latest in Gen AI and
				modern developer tools so you can stay productive, focused, and sane in the fast-moving world
				of AI and software development.
			</p>
		</main>
		<Footer />
	</body>
</html>
